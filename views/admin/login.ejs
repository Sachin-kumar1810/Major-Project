<% layout("/layouts/boilerplate") %>

<div class="row mt-5">
    <div class="col-6 offset-3">

        <h2>Admin Login</h2>

        <form method="POST" action="/admin/login">

            <div class="mb-3">
                <label class="form-label">Username</label>

                <input
                    type="text"
                    name="username"
                    class="form-control"
                    required
                >
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>

                <input
                    type="password"
                    name="password"
                    class="form-control"
                    required
                >
            </div>

            <button class="btn btn-dark">
                Login
            </button>

        </form>

    </div>
</div>